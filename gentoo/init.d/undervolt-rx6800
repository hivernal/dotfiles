#!/sbin/openrc-run

DEVICE="$(find /sys/devices -iname pp_power_profile_mode)"
DEVICE="${DEVICE%/*}"
HWMON="$(echo ${DEVICE}/hwmon/hwmon[0-9])"
CLK_VOLTAGE_FILE="${DEVICE}/pp_od_clk_voltage"
POWER_DPM_FILE="${DEVICE}/power_dpm_force_performance_level"
INTERVAL=1
SKEEP_ITER=10
PWM_FILE="${HWMON}/pwm1"
TEMP_FILE="${HWMON}/temp2_input"
TEMPS_PWMS="50000:0 55000:42 65000:70 75000:80 85000:90 110000:255"

supervisor=supervise-daemon
command=/usr/local/bin/control-fan.sh
command_args="-t '${TEMPS_PWMS}' -f '${TEMP_FILE}' -F '${PWM_FILE}' -i ${INTERVAL} -i ${SKEEP_ITER}"

set_fanmode() {
  local mode="$1"
  echo "${mode}" > "${PWM_FILE}_enable"
}

set_power_dpm() {
  local mode="$1"
  echo "${mode}" > "${POWER_DPM_FILE}"
}

set_manual_mode() {
  set_power_dpm "manual"
  set_fanmode 1
}

set_auto_mode() {
  set_power_dpm "auto"
  set_fanmode 2
}

checkconfig() {
  [ -n "${DEVICE}" ]
}

start_pre() {
  checkconfig || return $?
  echo "s 1 2200" > "${CLK_VOLTAGE_FILE}" &&
  echo "vo -100" > "${CLK_VOLTAGE_FILE}" &&
  echo "c" > "${CLK_VOLTAGE_FILE}"
  set_manual_mode
}

stop_pre() {
  checkconfig || return $?
}

stop_post() {
  set_auto_mode
  echo "r" > "${CLK_VOLTAGE_FILE}"
}
